{
    "name": "@lumelabs/eslint-config",
    "version": "0.4.0",
    "description": "Opinionated, batteries-included ESLint 9 (flat config) for TypeScript projects — frontend and backend.",
    "license": "MIT",
    "author": "Egor Arkhipov (Lumelabs)",
    "repository": {
        "type": "git",
        "url": "https://github.com/lumine-labs/eslint-config"
    },
    "files": [
        "index.cjs",
        "typescript.cjs",
        "rules",
        "README.md",
        "LICENSE.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "eslint",
        "eslint-config",
        "eslintconfig",
        "flat-config",
        "eslint9",
        "typescript",
        "react",
        "lint",
        "code-style"
    ],
    "main": "index.cjs",
    "exports": {
        ".": "./index.cjs",
        "./typescript": "./typescript.cjs"
    },
    "dependencies": {
        "@eslint/js": "^9.39.0",
        "confusing-browser-globals": "^1.0.11",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-node": "^0.3.9",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import-x": "^4.16.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.0",
        "globals": "^17.0.0",
        "typescript-eslint": "^8.61.0"
    },
    "peerDependencies": {
        "typescript": ">=5.0.0"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "devDependencies": {
        "prettier": "^3.8.1"
    }
}
